{
  "name": "budget-pc",
  "private": true,
  "version": "0.1.23",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:nsis": "tauri build --bundles nsis",
    "desktop:build:msi": "tauri build --bundles msi",
    "desktop:deliver": "tauri build --bundles nsis && powershell -ExecutionPolicy Bypass -File .\\scripts\\export-installer.ps1",
    "desktop:release:prepare": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare-updater-config.ps1",
    "desktop:release:nsis": "npm run desktop:release:prepare && tauri build --config src-tauri\\tauri.release.conf.json --bundles nsis",
    "desktop:release:stage": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stage-updater-release.ps1",
    "desktop:release:deliver": "npm run desktop:release:nsis && npm run desktop:release:stage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
